---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import logo from '../../assets/logo.png';

export async function getStaticPaths() {
  const meetups = await getCollection('meetups');
  return meetups.map((meetup) => ({
    params: { slug: meetup.id },
    props:  { meetup },
  }));
}

const { meetup } = Astro.props;
const d = meetup.data;

// ── Status computed from start/end ───────────────────────────
// NOTE: Astro runs this at BUILD time, so status is baked in at deploy.
// Re-deploy to update status as time passes.
const now    = new Date();
const start  = new Date(d.start);
const end    = new Date(d.end);
const status = now < start ? 'upcoming' : now <= end ? 'live' : 'past';

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString('en-GB', {
    weekday: 'long', day: 'numeric', month: 'long', year: 'numeric',
  });
}
function formatTime(iso: string): string {
  return new Date(iso).toLocaleTimeString('en-GB', {
    hour: '2-digit', minute: '2-digit', timeZone: 'Africa/Accra', timeZoneName: 'short',
  });
}

// ── Timezone helpers ────────────────────────────────────────
function parseTime12h(str: string): { h: number; m: number } | null {
  const m = str.match(/^(\d{1,2}):(\d{2})\s*(AM|PM)$/i);
  if (!m) return null;
  let h = +m[1];
  if (m[3].toUpperCase() === 'PM' && h !== 12) h += 12;
  if (m[3].toUpperCase() === 'AM' && h === 12) h = 0;
  return { h, m: +m[2] };
}
function scheduleToISO(dateISO: string, timeStr: string): string | null {
  const p = parseTime12h(timeStr);
  if (!p) return null;
  const d = new Date(dateISO);
  return new Date(Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate(), p.h, p.m)).toISOString();
}
const scheduleItems = (d.schedule ?? []).map(item => ({
  ...item,
  iso: scheduleToISO(d.start, item.time),
}));

const scheduleTypeLabel: Record<string, string> = {
  networking:     'Networking',
  talk:           'Talk',
  panel:          'Panel',
  workshop:       'Workshop',
  open_discussion:'Open Discussion',
  break:          'Break',
};

const photos = d.photos ?? [];
const imagePhotos = photos.filter((photo) => !photo.type || photo.type === 'image');
const folderPhotos = photos.filter((photo) => photo.type === 'folder');
---

<Base title={`${d.name} — DevCongress`} description={d.description}>

  <!-- Nav -->
  <header class="mnav">
    <div class="container mnav-inner">
      <a href="/" class="mnav-logo">
        <Image src={logo} alt="DevCongress" height="36" />
      </a>
      <a href="/#meetups" class="mnav-back">← All meetups</a>
    </div>
  </header>

  <main>

    <!-- ── Hero ───────────────────────────────────────────── -->
    <div class="meetup-hero" style={`background-image: url('${d.cover}')`} role="img" aria-label={`${d.name} cover`}>
      <div class="meetup-hero-overlay">
        <div class="container">
          <span class={`meetup-status status-${status}`}>
            {status === 'live' ? '● Live now' : status === 'upcoming' ? 'Upcoming' : 'Past'}
          </span>
          <h1 class="heading-serif meetup-title">{d.name}</h1>
          <div class="meetup-hero-meta">
            <span data-utc={d.start} data-display="datetime">{formatDate(d.start)} · {formatTime(d.start)}</span>
            {d.location.map_url
              ? <a href={d.location.map_url} target="_blank" rel="noopener noreferrer" class="meetup-location-link">
                  📍 {d.location.name}
                </a>
              : <span>📍 {d.location.name}</span>
            }
          </div>
        </div>
      </div>
    </div>
    
    <!-- ── About ──────────────────────────────────────────── -->
    <div class="about-section">
      <div class="container about-inner">
        <div>
          <span class="eyebrow">About</span>
          <p class="about-desc">{d.description}</p>
        </div>
        {status === 'past' && d.stream_url && !d.embed_stream && (
          <a href={d.stream_url} target="_blank" rel="noopener noreferrer" class="btn btn-outline">
            Watch recording →
          </a>
        )}
      </div>
    </div>

    <!-- ── Live: stream embed ─────────────────────────────── -->
    {status === 'live' && d.stream_url && d.embed_stream && (
      <div class="stream-section">
        <div class="container">
          <span class="eyebrow live-eyebrow">● Streaming now</span>
          <div class="stream-wrap card">
            <iframe
              src={d.stream_url}
              title={`${d.name} — Live stream`}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          </div>
        </div>
      </div>
    )}
    {status === 'live' && d.stream_url && !d.embed_stream && (
      <div class="stream-section">
        <div class="container">
          <span class="eyebrow live-eyebrow">● Streaming now</span>
          <a href={d.stream_url} target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-stream-link">
            Watch live →
          </a>
        </div>
      </div>
    )}

    <!-- ── Upcoming: registration CTA ────────────────────── -->
    {status === 'upcoming' && d.registration_url && (
      <div class="reg-section">
        <div class="container">
          <div class="reg-card card">
            <div class="reg-copy">
              <h2 class="heading-serif reg-heading">Join us at this meetup</h2>
              <p class="reg-meta"><span data-utc={d.start} data-display="datetime">{formatDate(d.start)} · {formatTime(d.start)}</span></p>
              <p class="reg-location">📍 {d.location.name}</p>
            </div>
            <a href={d.registration_url} target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-reg">
              Register now →
            </a>
          </div>
        </div>
      </div>
    )}

    {status === 'past' && d.stream_url && d.embed_stream && (
      <div class="stream-section">
        <div class="container">
          <span class="eyebrow">Recording</span>
          <div class="stream-wrap card">
            <iframe
              src={d.stream_url}
              title={`${d.name} — Recording`}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>
        </div>
      </div>
    )}

    <!-- ── Speakers ───────────────────────────────────────── -->
    {d.speakers && d.speakers.length > 0 && (
      <div class="speakers-section">
        <div class="container">
          <span class="eyebrow">Speakers</span>
          <h2 class="heading-serif section-heading">Who's speaking</h2>
          <ul class="speakers-grid">
            {d.speakers.map((speaker) => (
              <li class="speaker-card card">
                <div class="speaker-img-wrap">
                  <Image src={speaker.image} alt={speaker.name} width={400} height={400} loading="lazy" decoding="async" class="speaker-img" />
                </div>
                <div class="speaker-body">
                  <h3 class="speaker-name">{speaker.name}</h3>
                  <p class="speaker-title">{speaker.title}</p>
                  <p class="speaker-bio">{speaker.bio}</p>
                  {speaker.talk_title && (
                    <div class="speaker-talk">
                      <p class="speaker-talk-title">{speaker.talk_title}</p>
                      <p class="speaker-talk-desc">{speaker.talk_description}</p>
                    </div>
                  )}
                  <div class="speaker-links">
                    {status === 'past' && speaker.slides_url && (
                      <a href={speaker.slides_url} target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-sm">
                        Slides →
                      </a>
                    )}
                    {status === 'past' && speaker.recording_url && (
                      <a href={speaker.recording_url} target="_blank" rel="noopener noreferrer" class="btn btn-outline btn-sm">
                        Recording →
                      </a>
                    )}
                    {speaker.socials?.map((s) => (
                      <a href={s.url} target="_blank" rel="noopener noreferrer" class="speaker-social">
                        {s.platform}
                      </a>
                    ))}
                  </div>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </div>
    )}

    <!-- ── Schedule ───────────────────────────────────────── -->
    {d.schedule && d.schedule.length > 0 && (
      <div class="schedule-section">
        <div class="container">
          <div class="schedule-header-row">
            <span class="eyebrow">{status === 'past' ? 'Recap' : 'Schedule'}</span>
            <div class="tz-switch" role="radiogroup" aria-label="Time zone">
              <span class="tz-switch-label tz-switch-label--active" data-tz-label="event">Event Time (GMT+0)</span>
              <button class="tz-switch-track" role="radio" aria-checked="true" data-tz="event">
                <span class="tz-switch-knob"></span>
              </button>
              <span class="tz-switch-label" data-tz-label="local">My Time</span>
            </div>
          </div>
          <h2 class="heading-serif section-heading">
            {status === 'past' ? 'How the day went' : 'How the day will go'}
          </h2>
          <ol class="schedule-list">
            {scheduleItems.map((item) => (
              <li class="schedule-item">
                <div class="schedule-time" data-utc={item.iso} data-display="time">{item.time}</div>
                <div class="schedule-content">
                  <div class="schedule-top">
                    <h3 class="schedule-title">{item.title}</h3>
                    <span class={`schedule-type type-${item.type}`}>
                      {scheduleTypeLabel[item.type]}
                    </span>
                  </div>
                  {item.lead && (
                    <p class="schedule-lead">Led by {item.lead}</p>
                  )}
                  {item.resources && item.resources.length > 0 && (
                    <ul class="schedule-resources">
                      {item.resources.map((r) => (
                        <li>
                          <a href={r.url} target="_blank" rel="noopener noreferrer" class="resource-link">
                            {r.title} →
                          </a>
                        </li>
                      ))}
                    </ul>
                  )}
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    )}

    <!-- ── Photos (past only) ─────────────────────────────── -->
    {status === 'past' && imagePhotos.length > 0 && (
      <div class="photos-section">
        <div class="container">
          <div class="photos-header">
            <span class="eyebrow">Gallery</span>
            <span class="photos-count">{imagePhotos.length} photos</span>
          </div>
          <ul class="photos-grid" data-photo-grid>
            {imagePhotos.map((photo, i) => (
              <li class="photo-item">
                <button
                  type="button"
                  class="photo-trigger"
                  data-photo-src={photo.url}
                  data-photo-alt={`${d.name} — photo ${i + 1}`}
                  aria-label={`Expand photo ${i + 1}`}
                >
                  <Image src={photo.url} alt={`${d.name} — photo ${i + 1}`} width={1600} height={1200} loading="lazy" decoding="async" />
                </button>
              </li>
            ))}
          </ul>
        </div>
      </div>
    )}

    {status === 'past' && folderPhotos.length > 0 && (
      <div class="folders-section">
        <div class="container">
          <div class="photos-header">
            <span class="eyebrow">Photo folders</span>
            <span class="photos-count">{folderPhotos.length} folders</span>
          </div>
          <ul class="folders-grid">
            {folderPhotos.map((photo, i) => (
              <li class="folder-item card">
                <a href={photo.url} target="_blank" rel="noopener noreferrer" class="folder-link">
                  <span class="folder-icon" aria-hidden="true">📁</span>
                  <span class="folder-copy">Open folder {i + 1} →</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    )}

    {status === 'past' && imagePhotos.length > 0 && (
      <div class="lightbox-overlay" data-lightbox hidden>
        <button type="button" class="lightbox-close" data-lightbox-close aria-label="Close image viewer">✕</button>
        <img class="lightbox-image" data-lightbox-image src="" alt="" />
      </div>
    )}

    <!-- ── Videos (past only) ────────────────────────────── -->
    {status === 'past' && d.videos && d.videos.length > 0 && (
      <div class="videos-section">
        <div class="container">
          <span class="eyebrow">Recordings</span>
          <h2 class="heading-serif section-heading">Watch the talks</h2>
          <ul class="videos-grid">
            {d.videos.map((video) => (
              <li class="video-card card">
                <div class="video-wrap">
                  <iframe
                    src={video.embed_url}
                    title={video.title}
                    loading="lazy"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                  ></iframe>
                </div>
                <p class="video-title">{video.title}</p>
              </li>
            ))}
          </ul>
        </div>
      </div>
    )}

  </main>
</Base>

<style>
  /* ── Nav ──────────────────────────────────────────────── */
  .mnav {
    position: sticky; top: 0; z-index: 100;
    background: var(--bg); border-bottom: 2px solid var(--black);
    padding-block: var(--s4);
  }
  .mnav-inner { display: flex; align-items: center; justify-content: space-between; }
  .mnav-back  { font-size: var(--text-sm); font-weight: 500; color: var(--text-mid); transition: color 150ms ease; }
  .mnav-back:hover { color: var(--pink); }

  /* ── Hero ────────────────────────────────────────────── */
  .meetup-hero {
    width: 100%; aspect-ratio: 21/9;
    background-size: cover; background-position: center;
    background-color: var(--border-light);
    position: relative; display: flex; align-items: flex-end;
  }
  @media (max-width: 640px) { .meetup-hero { aspect-ratio: 4/3; } }

  .meetup-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.3) 50%, transparent 100%);
    display: flex; align-items: flex-end; padding-bottom: var(--s8); width: 100%;
  }

  .meetup-status {
    display: inline-block;
    font-size: var(--text-xs); font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase; padding: 3px var(--s3);
    border: 2px solid currentColor; border-radius: var(--r-full);
    margin-bottom: var(--s4);
  }
  .status-upcoming { color: var(--yellow); }
  .status-live     { color: var(--pink); }
  .status-past     { color: rgba(255,255,255,0.6); }

  .meetup-title {
    font-size: clamp(var(--text-3xl), 6vw, var(--text-4xl));
    color: #fff; margin-bottom: var(--s4); line-height: var(--leading-tight);
  }

  .meetup-hero-meta {
    display: flex; flex-wrap: wrap; align-items: center; gap: var(--s4);
    font-size: var(--text-sm); color: rgba(255,255,255,0.75);
  }
  .meetup-location-link { color: rgba(255,255,255,0.75); text-decoration: underline; text-underline-offset: 3px; }
  .meetup-location-link:hover { color: var(--yellow); }

  /* ── Stream ──────────────────────────────────────────── */
  .stream-section { padding-block: var(--s8); border-bottom: 2px solid var(--black); }
  .live-eyebrow { color: var(--pink); }
  .stream-wrap { overflow: hidden; margin-top: var(--s5); box-shadow: 8px 8px 0 var(--pink); }
  .stream-wrap:hover { transform: translate(8px, 8px); box-shadow: 0 0 0 transparent; }
  .stream-wrap iframe { width: 100%; aspect-ratio: 16/9; border: none; display: block; }
  .btn-stream-link { margin-top: var(--s5); }

  /* ── Registration ────────────────────────────────────── */
  .reg-section { padding-block: var(--s8); border-bottom: 2px solid var(--black); background: var(--yellow); }
  .reg-card {
    display: flex; flex-wrap: wrap; align-items: center;
    justify-content: space-between; gap: var(--s6);
    padding: var(--s7); box-shadow: 6px 6px 0 var(--black);
  }
  .reg-card:hover {
    transform: translate(6px, 6px);
    box-shadow: 0 0 0 transparent;
  }
  .reg-heading { font-size: var(--text-2xl); margin-bottom: var(--s3); }
  .reg-meta, .reg-location { font-size: var(--text-sm); color: var(--text-mid); margin-bottom: var(--s2); }
  .btn-reg { padding: var(--s4) var(--s8); font-size: var(--text-lg); white-space: nowrap; }

  /* ── About ───────────────────────────────────────────── */
  .about-section { padding-block: var(--s8); border-bottom: 2px solid var(--black); background: var(--bg-white); }
  .about-inner { display: flex; flex-wrap: wrap; align-items: flex-start; justify-content: space-between; gap: var(--s6); }
  .about-desc { font-size: var(--text-lg); color: var(--text-mid); line-height: var(--leading-body); max-width: 680px; }

  /* ── Speakers ────────────────────────────────────────── */
  .speakers-section { padding-block: var(--s9); border-bottom: 2px solid var(--black); }
  .section-heading { font-size: clamp(var(--text-2xl), 4vw, var(--text-3xl)); margin-bottom: var(--s7); }

  .speakers-grid {
    display: grid; grid-template-columns: minmax(0, 1fr); gap: var(--s5);
  }
  @media (min-width: 640px)  { .speakers-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (min-width: 1024px) { .speakers-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }

  .speaker-card { overflow: hidden; display: flex; flex-direction: column; }

  .speaker-img-wrap { width: 100%; aspect-ratio: 1/1; overflow: hidden; border-bottom: 2px solid var(--black); background: var(--border-light); }
  .speaker-img { width: 100%; height: 100%; object-fit: cover; object-position: top; filter: grayscale(0.15); transition: filter 300ms ease, transform 300ms ease; }
  .speaker-card:hover .speaker-img { filter: grayscale(0); transform: scale(1.04); }

  .speaker-body { padding: var(--s5); display: flex; flex-direction: column; gap: var(--s3); }
  .speaker-name  { font-size: var(--text-lg); font-weight: 700; color: var(--text); }
  .speaker-title { font-size: var(--text-sm); color: var(--pink); font-weight: 600; }
  .speaker-bio   { font-size: var(--text-sm); color: var(--text-mid); line-height: var(--leading-body); }

  .speaker-talk { border-top: 1px solid var(--border-light); padding-top: var(--s3); }
  .speaker-talk-title { font-size: var(--text-sm); font-weight: 700; color: var(--text); margin-bottom: var(--s1); }
  .speaker-talk-desc  { font-size: var(--text-sm); color: var(--text-mid); line-height: var(--leading-body); }

  .speaker-links { display: flex; flex-wrap: wrap; gap: var(--s2); margin-top: var(--s2); }
  .btn-sm { padding: var(--s2) var(--s4); font-size: var(--text-xs); }
  .speaker-social {
    font-size: var(--text-xs); font-weight: 600; color: var(--text-muted);
    text-transform: capitalize; padding: 3px var(--s3);
    border: 1px solid var(--border-light); border-radius: var(--r-full);
    transition: color 150ms, border-color 150ms;
  }
  .speaker-social:hover { color: var(--pink); border-color: var(--pink); }

  /* ── Schedule ────────────────────────────────────────── */
  .schedule-section { padding-block: var(--s9); border-bottom: 2px solid var(--black); background: var(--bg-white); }

  .schedule-header-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  /* ── Timezone switch ────────────────────────────────── */
  .tz-switch {
    display: inline-flex;
    align-items: center;
    gap: var(--s2);
    flex-shrink: 0;
    cursor: pointer;
    user-select: none;
  }

  .tz-switch-label {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--text-muted);
    transition: color 150ms ease;
    pointer-events: none;
  }
  .tz-switch-label--active {
    color: var(--text);
  }
  .tz-switch-label--active[data-tz-label="event"] {
    color: var(--yellow-dark);
  }
  .tz-switch-label--active[data-tz-label="local"] {
    color: var(--pink);
  }

  .tz-switch-track {
    position: relative;
    width: 48px;
    height: 26px;
    border: 2px solid var(--black);
    border-radius: var(--r-full);
    background: var(--bg-white);
    padding: 0;
    cursor: pointer;
    transition: background 200ms ease;
  }
  .tz-switch-track[aria-checked="true"] {
    background: var(--yellow-bg);
  }
  .tz-switch-track[aria-checked="false"] {
    background: var(--pink-light);
  }

  .tz-switch-knob {
    position: absolute;
    top: 2px;
    left: 2px;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: var(--black);
    transition: transform 250ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .tz-switch-track[aria-checked="false"] .tz-switch-knob {
    transform: translateX(22px);
  }

  .schedule-list { display: flex; flex-direction: column; border-top: 2px solid var(--black); }

  .schedule-item {
    display: grid; grid-template-columns: 80px minmax(0, 1fr); gap: var(--s5);
    padding-block: var(--s5); border-bottom: 2px solid var(--black);
    transition: background 150ms ease;
  }
  .schedule-item:hover { background: var(--yellow-bg); }

  .schedule-time {
    font-size: var(--text-sm); font-weight: 700; color: var(--text-muted);
    padding-top: 2px; white-space: nowrap;
  }

  .schedule-content { display: flex; flex-direction: column; gap: var(--s2); }

  .schedule-top { display: flex; align-items: flex-start; justify-content: space-between; gap: var(--s3); flex-wrap: wrap; }

  .schedule-title { font-family: var(--font-serif); font-size: var(--text-lg); color: var(--text); line-height: var(--leading-snug); }

  .schedule-type {
    font-size: var(--text-xs); font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.06em; padding: 2px var(--s3);
    border-radius: var(--r-full); border: 1.5px solid currentColor;
    white-space: nowrap; flex-shrink: 0;
  }
  .type-networking     { color: #059669; }
  .type-talk           { color: var(--pink); }
  .type-panel          { color: #7c3aed; }
  .type-workshop       { color: #d97706; }
  .type-open_discussion{ color: #0284c7; }
  .type-break          { color: var(--text-muted); }

  .schedule-lead { font-size: var(--text-sm); color: var(--text-mid); font-style: italic; }

  .schedule-resources { display: flex; flex-wrap: wrap; gap: var(--s2); margin-top: var(--s1); }
  .resource-link {
    font-size: var(--text-xs); font-weight: 600; color: var(--pink);
    padding: 5px var(--s3); border: 1px solid var(--pink-light);
    border-radius: var(--r-full); background: var(--pink-light);
    transition: background 150ms, border-color 150ms;
  }
  .resource-link:hover { background: var(--pink); color: #fff; border-color: var(--pink); }

  /* ── Photos ──────────────────────────────────────────── */
  .photos-section { padding-block: var(--s9); border-bottom: 2px solid var(--black); }
  .photos-header { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: var(--s6); }
  .photos-count { font-size: var(--text-sm); font-weight: 600; color: var(--text-muted); }

  .photos-grid {
    display: grid; grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--s3); border: 2px solid var(--black); border-radius: var(--r-md); overflow: hidden;
  }
  @media (min-width: 640px)  { .photos-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
  @media (min-width: 1024px) { .photos-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); } }

  .photo-item { aspect-ratio: 4/3; overflow: hidden; background: var(--border-light); position: relative; }
  .photo-trigger { width: 100%; height: 100%; border: none; background: none; padding: 0; cursor: zoom-in; }
  .photo-item img { width: 100%; height: 100%; object-fit: cover; transition: transform 400ms ease; }
  .photo-item:hover img { transform: scale(1.06); }

  .folders-section { padding-block: var(--s8); border-bottom: 2px solid var(--black); }
  .folders-grid { display: grid; grid-template-columns: minmax(0, 1fr); gap: var(--s4); }
  @media (min-width: 720px) { .folders-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  .folder-item { padding: var(--s5); }
  .folder-link {
    display: flex; align-items: center; gap: var(--s3); text-decoration: none;
    color: var(--text-mid); font-weight: 600;
  }
  .folder-link:hover { color: var(--text); }
  .folder-icon { font-size: 1.5rem; }
  .folder-copy { font-size: var(--text-sm); }

  .lightbox-overlay {
    position: fixed; inset: 0; z-index: 1000;
    display: flex; align-items: center; justify-content: center;
    background: rgba(0, 0, 0, 0.88);
  }
  .lightbox-overlay[hidden] { display: none !important; }
  .lightbox-image {
    max-width: 92vw; max-height: 90vh; object-fit: contain;
    border-radius: var(--r-sm); box-shadow: 0 8px 48px rgba(0, 0, 0, 0.55);
  }
  .lightbox-close {
    position: fixed; top: var(--s5); right: var(--s5);
    width: 44px; height: 44px; border-radius: 50%; border: none;
    font-size: 1.5rem; color: #fff; background: rgba(0, 0, 0, 0.55);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
  }
  .lightbox-close:hover { background: rgba(0, 0, 0, 0.8); }

  /* ── Videos ──────────────────────────────────────────── */
  .videos-section { padding-block: var(--s9); }

  .videos-grid {
    display: grid; grid-template-columns: minmax(0, 1fr); gap: var(--s5);
  }
  @media (min-width: 720px) { .videos-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }

  .video-card { overflow: hidden; }
  .video-wrap { border-bottom: 2px solid var(--black); }
  .video-wrap iframe { width: 100%; aspect-ratio: 16/9; border: none; display: block; }
  .video-title { padding: var(--s4) var(--s5); font-size: var(--text-sm); font-weight: 600; color: var(--text); }
</style>

<script is:inline>
  (() => {
    /* ── Lightbox ─────────────────────────────────────── */
    const lightbox = document.querySelector('[data-lightbox]');
    const lightboxImage = document.querySelector('[data-lightbox-image]');
    const closeButton = document.querySelector('[data-lightbox-close]');
    const photoTriggers = Array.from(document.querySelectorAll('.photo-trigger'));
    let currentIndex = -1;

    if (lightbox && lightboxImage) {
      function openImageAt(index) {
        if (!photoTriggers.length) return;
        const normalized = (index + photoTriggers.length) % photoTriggers.length;
        const trigger = photoTriggers[normalized];
        const src = trigger.dataset.photoSrc;
        if (!src) return;
        currentIndex = normalized;
        lightboxImage.src = src;
        lightboxImage.alt = trigger.dataset.photoAlt ?? 'Meetup photo';
        lightbox.hidden = false;
        document.body.style.overflow = 'hidden';
      }
      function closeLightbox() {
        lightbox.hidden = true;
        lightboxImage.src = '';
        lightboxImage.alt = '';
        currentIndex = -1;
        document.body.style.overflow = '';
      }
      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        const trigger = target.closest('.photo-trigger');
        if (trigger instanceof HTMLElement) {
          const clickedIndex = photoTriggers.indexOf(trigger);
          if (clickedIndex === -1) return;
          openImageAt(clickedIndex);
          return;
        }
        if (target === lightbox || target === closeButton) closeLightbox();
      });
      document.addEventListener('keydown', (event) => {
        if (lightbox.hidden) return;
        if (event.key === 'Escape') { closeLightbox(); return; }
        if (event.key === 'ArrowRight') { event.preventDefault(); openImageAt(currentIndex + 1); return; }
        if (event.key === 'ArrowLeft') { event.preventDefault(); openImageAt(currentIndex - 1); }
      });
    }

    /* ── Timezone switch ──────────────────────────────── */
    const tzSwitch = document.querySelector('.tz-switch');
    const EVENT_TZ = 'Africa/Accra';
    const STORAGE_KEY = 'dc-tz';

    function fmtOpts(tz, extra) {
      const o = { ...extra };
      if (tz !== 'local') o.timeZone = tz;
      return o;
    }
    function formatDate(iso, tz) {
      const d = new Date(iso);
      return d.toLocaleDateString('en-GB', fmtOpts(tz, { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' }));
    }
    function formatTime(iso, tz) {
      const d = new Date(iso);
      return d.toLocaleTimeString('en-GB', fmtOpts(tz, { hour: '2-digit', minute: '2-digit', timeZoneName: 'short' }));
    }

    function getUserTZLabel() {
      const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
      const parts = new Intl.DateTimeFormat('en', {
        timeZone: tz, timeZoneName: 'shortOffset',
      }).formatToParts();
      return parts.find(p => p.type === 'timeZoneName')?.value || tz;
    }

    function applyTimezone(tz) {
      document.querySelectorAll('[data-utc]').forEach(el => {
        const iso = el.dataset.utc;
        if (!iso) return;
        if (el.dataset.display === 'time') {
          el.textContent = formatTime(iso, tz);
        } else {
          el.textContent = formatDate(iso, tz) + ' \u00b7 ' + formatTime(iso, tz);
        }
      });
      const track = document.querySelector('.tz-switch-track');
      if (track) {
        const isLocal = tz === 'local';
        track.dataset.tz = isLocal ? 'local' : 'event';
        track.setAttribute('aria-checked', String(!isLocal));
      }
      document.querySelectorAll('.tz-switch-label').forEach(lbl => {
        const isActive = lbl.dataset.tzLabel === 'local' ? tz === 'local' : tz !== 'local';
        lbl.classList.toggle('tz-switch-label--active', isActive);
      });
      const localLabel = document.querySelector('[data-tz-label="local"]');
      if (localLabel) {
        localLabel.textContent = 'My Time (' + getUserTZLabel() + ')';
      }
    }

    if (tzSwitch) {
      const saved = localStorage.getItem(STORAGE_KEY);
      applyTimezone(saved === 'local' ? 'local' : EVENT_TZ);

      tzSwitch.addEventListener('click', () => {
        const track = document.querySelector('.tz-switch-track');
        if (!track) return;
        const current = track.dataset.tz === 'local' ? 'local' : 'event';
        const next = current === 'local' ? EVENT_TZ : 'local';
        localStorage.setItem(STORAGE_KEY, next === 'local' ? 'local' : 'event');
        applyTimezone(next);
      });
    }
  })();
</script>
