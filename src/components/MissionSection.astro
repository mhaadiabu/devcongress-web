---
interface MissionItem { heading: string; description: string; }
interface MissionSection {
  eyebrow: string;
  headline: string;
  body: string;
  cta: string;
  items: MissionItem[];
}
interface Props { mission: MissionSection; slackUrl: string; }
const { mission, slackUrl } = Astro.props;

function parseEmphasis(text: string): { plain: boolean; text: string }[] {
  return text.split(/\*(.+?)\*/).map((part, i) => ({
    plain: i % 2 === 0,
    text: part,
  }));
}

const headlineParts = parseEmphasis(mission.headline);
---

<section class="section" id="community">
  <div class="container">

    <div class="mission-grid">

      <div class="mission-left">
        <span class="eyebrow">{mission.eyebrow}</span>
        <h2 class="heading-serif mission-headline">
          {headlineParts.map((part) =>
            part.plain
              ? part.text
              : <span class="mission-pink">{part.text}</span>
          )}
        </h2>
        <p class="mission-body">{mission.body}</p>
        <a href={slackUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-mission">
          {mission.cta}
        </a>
      </div>

      <ol class="mission-list">
        {mission.items.map((item, i) => (
          <li class="mission-item">
            <div class="mission-num">{String(i + 1).padStart(2, '0')}</div>
            <div class="mission-content">
              <h3 class="mission-item-heading">
                {parseEmphasis(item.heading).map((part) =>
                  part.plain
                    ? part.text
                    : <span class="mission-pink">{part.text}</span>
                )}
              </h3>
              <p class="mission-item-desc">{item.description}</p>
            </div>
          </li>
        ))}
      </ol>

    </div>
  </div>
</section>

<style>
  .mission-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--s7);
  }

  @media (min-width: 900px) {
    .mission-grid {
      grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
      gap: var(--s10);
      align-items: start;
    }
  }

  .mission-left {
    display: flex;
    flex-direction: column;
    gap: var(--s5);
    text-align: center;
  }

  @media (min-width: 900px) {
    .mission-left {
      text-align: left;
    }
  }

  @media (min-width: 900px) {
    .mission-grid {
      grid-template-columns: 5fr 7fr;
      gap: var(--s10);
      align-items: start;
    }
    .mission-left {
      position: sticky;
      top: 88px;
    }
  }

  .mission-headline {
    font-size: clamp(var(--text-2xl), 3vw, var(--text-3xl));
    line-height: var(--leading-snug);
    max-width: 100%;
  }

  .mission-pink { color: var(--pink); }

  .btn-mission {
    padding: var(--s4) var(--s8);
    font-size: var(--text-lg);
    align-self: stretch;
    justify-content: center;
  }

  @media (min-width: 900px) {
    .btn-mission {
      align-self: flex-start;
    }
  }

  .mission-body {
    font-size: var(--text-base);
    color: var(--text-mid);
    line-height: var(--leading-body);
    max-width: 100%;
  }

  .mission-list {
    display: flex;
    flex-direction: column;
    border-top: 2px solid var(--black);
  }

  .mission-item {
    display: grid;
    grid-template-columns: 40px minmax(0, 1fr);
    gap: var(--s5);
    padding-block: var(--s6);
    border-bottom: 2px solid var(--black);
    transition: background 150ms ease;
  }
  .mission-item:hover { background: var(--yellow-bg); }

  .mission-num {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    color: var(--pink);
    line-height: 1.2;
    padding-top: 2px;
  }

  .mission-content { display: flex; flex-direction: column; gap: var(--s2); }

  .mission-item-heading {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    line-height: var(--leading-snug);
    color: var(--text);
  }

  .mission-item-desc {
    font-size: var(--text-sm);
    color: var(--text-mid);
    line-height: var(--leading-body);
  }
</style>
