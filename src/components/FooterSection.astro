---
interface Social { platform: string; url: string; }
interface Props { socials: Social[]; }
const { socials } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-body">

    <div class="footer-brand">
      <a href="/" aria-label="DevCongress home">
        <img src="/images/logo.png" alt="dev:congress{};" height="36" />
      </a>
      <p class="footer-tagline">Africa's home for builders.</p>
      <a href="mailto:hello@devcongress.org" class="footer-email">
        hello@devcongress.org
      </a>
    </div>

    <nav class="footer-nav" aria-label="Footer links">
      <p class="footer-nav-label">Links</p>
      <ul>
        <li><a href="#community">Community</a></li>
        <li><a href="#programs">Programs</a></li>
        <li><a href="#meetups">Meetups</a></li>
        <li><a href="#admins">Admins</a></li>
        <li><a href="#partners">Partners</a></li>
        <li><a href="#donate">Support Us</a></li>
      </ul>
    </nav>

    <div class="footer-social">
      <p class="footer-nav-label">Find us</p>
      <ul>
        {socials.map((s) => (
          <li>
            <a href={s.url} target="_blank" rel="noopener noreferrer" class="footer-social-link">
              {s.platform}
            </a>
          </li>
        ))}
      </ul>
    </div>

  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <span>&copy; {year} DevCongress. Built by the community, for the community.</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    overflow: hidden;
    border-top: 2px solid #111;
    background:
      radial-gradient(1200px 320px at 20% -10%, rgba(255, 217, 102, 0.14), transparent 60%),
      linear-gradient(180deg, #0f0f11 0%, #070708 100%);
    color: #f5f5f5;
  }

  .footer-body {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s7);
    padding-block: var(--s9);
  }
  @media (min-width: 860px) {
    .footer-body {
      grid-template-columns: 1.15fr 1.75fr 1.1fr;
      column-gap: var(--s6);
      row-gap: var(--s7);
    }
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: var(--s5);
    max-width: 40ch;
  }

  .footer-brand img {
    border-radius: 4px;
    box-shadow: 0 8px 18px rgba(0, 0, 0, 0.35);
  }

  .footer-tagline {
    font-size: var(--text-base);
    color: #b6bbc5;
    line-height: var(--leading-body);
  }

  .footer-email {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    min-height: 36px;
    padding: 8px 14px;
    border: 1px solid #303236;
    border-radius: var(--r-full);
    background: rgba(255, 255, 255, 0.03);
    font-size: var(--text-xs);
    color: #c1c5ce;
    transition: color 150ms ease, border-color 150ms ease, background 150ms ease;
  }
  .footer-email:hover {
    color: #fff;
    border-color: #666;
    background: rgba(255, 255, 255, 0.06);
  }

  .footer-nav-label {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--yellow);
    margin-bottom: var(--s4);
  }

  .footer-nav,
  .footer-social {
    display: flex;
    flex-direction: column;
  }

  .footer-nav ul,
  .footer-social ul {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-social ul { max-width: 320px; }

  .footer-nav a,
  .footer-social-link {
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    padding: 8px 14px;
    border: 1px solid #303236;
    border-radius: var(--r-full);
    background: rgba(255, 255, 255, 0.03);
    font-size: var(--text-xs);
    color: #b4bac6;
    transition: color 160ms ease, border-color 160ms ease, background 160ms ease, transform 160ms ease;
  }
  .footer-nav a:hover,
  .footer-social-link:hover {
    color: #fff;
    border-color: #8a6f2d;
    background: rgba(255, 217, 102, 0.14);
    transform: translateY(-1px);
  }

  .footer-nav a:focus-visible,
  .footer-social-link:focus-visible {
    outline: 2px solid var(--yellow);
    outline-offset: 2px;
  }

  .footer-social-link {
    text-transform: capitalize;
  }

  .footer-bottom {
    border-top: 1px solid #22252b;
    background: rgba(0, 0, 0, 0.24);
    padding-block: var(--s4);
  }

  .footer-bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--s3);
    font-size: var(--text-xs);
    color: #8a8f99;
  }

  .footer-bottom-inner a {
    color: #8a8f99;
    transition: color 150ms ease;
  }
  .footer-bottom-inner a:hover { color: #d7dbe2; }
</style>
