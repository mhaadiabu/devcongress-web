---
import { Image } from 'astro:assets';

interface Partner {
  id: string;
  data: { name: string; logo: string; url?: string; backgroundColor?: string; width?: number; height?: number; };
}
interface Props { partners: Partner[]; }
const { partners } = Astro.props;
const sortedPartners = [...partners].sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<section class="section" id="partners">
  <div class="container">
    <span class="eyebrow">Partners</span>
    <h2 class="heading-serif partners-heading">Built with support</h2>

    <ul class="partner-row">
      {sortedPartners.map((p) => {
        const dims = { width: p.data.width ?? 300, height: p.data.height ?? 100 };
        return (
          <li class="partner-item">
            {p.data.url
              ? <a href={p.data.url} target="_blank" rel="noopener noreferrer" aria-label={p.data.name}>
                  <Image
                    src={p.data.logo}
                    alt={p.data.name}
                    width={dims.width}
                    height={dims.height}
                    loading="lazy"
                    class={p.data.backgroundColor ? 'has-bg' : ''}
                    style={p.data.backgroundColor ? 'background-color:' + p.data.backgroundColor : ''}
                  />
                </a>
              : <Image
                  src={p.data.logo}
                  alt={p.data.name}
                  width={dims.width}
                  height={dims.height}
                  loading="lazy"
                  class={p.data.backgroundColor ? 'has-bg' : ''}
                  style={p.data.backgroundColor ? 'background-color:' + p.data.backgroundColor : ''}
                />
            }
          </li>
        );
      })}
    </ul>
  </div>
</section>

<style>
  .partners-heading {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-4xl));
    margin-bottom: var(--s8);
  }

  .partner-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: flex-start;
    column-gap: 24px;
    row-gap: 24px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .partner-item { flex: 0 0 auto; }

  .partner-item a,
  .partner-item img {
    display: block;
  }

  .partner-item img {
    height: 100px;
    width: auto;
    object-fit: contain;
  }

  .partner-item img.has-bg {
    padding: 8px;
    border-radius: var(--r-md);
  }
</style>
