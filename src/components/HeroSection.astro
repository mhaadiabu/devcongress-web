---
interface Cta { text: string; color: 'pink' | 'outline' | 'white' | 'yellow'; }
interface Hero {
  eyebrow: string;
  headline: string;
  cta_primary: Cta;
  cta_secondary: Cta;
  video_label: string;
  video_live: string;
}
interface Props {
  hero: Hero;
  slackUrl: string;
  paystackUrl: string;
  youtubeEmbedUrl: string;
}
const { hero, slackUrl, paystackUrl, youtubeEmbedUrl } = Astro.props;

const colorClass: Record<string, string> = {
  pink:    'btn-primary',
  outline: 'btn-outline',
  white:   'btn-white',
  yellow:  'btn-yellow',
};
---

<section class="hero" id="hero">
  <div class="container">

    <div class="hero-top">
      <span class="eyebrow">{hero.eyebrow}</span>
      <h1 class="heading-serif hero-headline">{hero.headline}</h1>
      <div class="hero-ctas">
        <a
          href={slackUrl}
          target="_blank"
          rel="noopener noreferrer"
          class={`btn ${colorClass[hero.cta_primary.color]} btn-hero`}
        >
          {hero.cta_primary.text}
        </a>
        <a
          href={paystackUrl}
          target="_blank"
          rel="noopener noreferrer"
          class={`btn ${colorClass[hero.cta_secondary.color]} btn-hero`}
        >
          {hero.cta_secondary.text}
        </a>
      </div>
    </div>

  </div>

  <div class="hero-video-wrap">
    <div class="hero-video-bar">
      <span class="hero-video-label">{hero.video_label}</span>
      <span class="hero-video-live">{hero.video_live}</span>
    </div>
    <div class="hero-video">
      <iframe
        src={youtubeEmbedUrl}
        title="DevCongress — Community Highlight"
        loading="lazy"
        referrerpolicy="strict-origin-when-cross-origin"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
      ></iframe>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: clamp(3rem, 6vw, 5rem);
    padding-bottom: 0;
  }

  .hero-top {
    max-width: 900px;
    margin-inline: auto;
    margin-bottom: var(--s9);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-headline {
    font-size: clamp(var(--text-3xl), 7vw, var(--text-5xl));
    margin-bottom: var(--s7);
    letter-spacing: -0.01em;
  }

  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: var(--s4);
    justify-content: center;
  }

  .btn-hero {
    padding: var(--s4) var(--s7);
    font-size: var(--text-lg);
  }

  @media (min-width: 600px) {
    .btn-hero {
      padding: var(--s5) var(--s9);
    }
  }

  .hero-video-wrap {
    margin-inline: var(--pad);
    margin-bottom: var(--s9);
    border: 4px solid var(--black);
    border-radius: var(--r-lg);
    overflow: hidden;
    box-shadow: 8px 8px 0 var(--pink);
  }

  .hero-video-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--s3) var(--s5);
    background: var(--yellow);
    border-bottom: 4px solid var(--black);
  }

  .hero-video-label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--black);
  }

  .hero-video-live {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--pink);
    letter-spacing: 0.06em;
  }

  .hero-video iframe {
    width: 100%;
    aspect-ratio: 16 / 9;
    border: none;
    display: block;
  }
</style>
