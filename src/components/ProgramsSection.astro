---
interface Activity {
  id: string;
  data: {
    title: string;
    description: string;
    link?: string;
    color: string;
    order: number;
    status: 'active' | 'ongoing' | 'upcoming' | 'completed';
  };
}
interface Props { activities: Activity[]; }
const { activities } = Astro.props;
const sorted = [...activities].sort((a, b) => a.data.order - b.data.order);
const statusLabel: Record<string, string> = {
  active: 'Active',
  ongoing: 'Ongoing',
  upcoming: 'Upcoming',
  completed: 'Completed',
};
const isExternal = (url?: string) => Boolean(url && url.startsWith('http'));
---

<section class="section" id="programs">
  <div class="container">

    <div class="programs-header">
      <span class="eyebrow">Programs</span>
      <h2 class="heading-serif programs-heading">What we do</h2>
      <p class="programs-sub">Community-built programs, open to everyone. No barriers.</p>
    </div>

    <ul class="programs-grid">
      {sorted.map((activity) => (
        <li class="program-card card">
          <div class="program-top">
            <span
              class="program-dot"
              style={`background: ${activity.data.color}`}
              aria-hidden="true"
            ></span>
            <span class={`badge badge-${activity.data.status}`}>
              {statusLabel[activity.data.status]}
            </span>
          </div>
          <h3 class="heading-serif program-title">
            {activity.data.link ? (
              <a
                href={activity.data.link}
                {...(isExternal(activity.data.link) ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
              >{activity.data.title}</a>
            ) : (
              <span>{activity.data.title}</span>
            )}
          </h3>
          <p class="program-desc">{activity.data.description}</p>
          {activity.data.link && (
            <a
              href={activity.data.link}
              class="program-link"
              {...(isExternal(activity.data.link) ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              Learn more →
            </a>
          )}
        </li>
      ))}
    </ul>

  </div>
</section>

<style>
  .programs-header {
    margin-bottom: var(--s8);
    display: flex;
    flex-direction: column;
    gap: var(--s2);
  }

  .programs-heading {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-4xl));
  }

  .programs-sub {
    font-size: var(--text-base);
    color: var(--text-mid);
  }

  .programs-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--s5);
  }
  @media (min-width: 640px)  { .programs-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  @media (min-width: 1024px) { .programs-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }

  .program-card {
    padding: var(--s6);
    display: flex;
    flex-direction: column;
    gap: var(--s4);
  }

  .program-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .program-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid var(--black);
    flex-shrink: 0;
  }

  .program-title {
    font-size: var(--text-2xl);
    line-height: var(--leading-snug);
    transition: color 150ms ease;
  }
  .program-title a:hover { color: var(--pink); }

  .program-desc {
    font-size: var(--text-sm);
    color: var(--text-mid);
    line-height: var(--leading-body);
    flex: 1;
  }

  .program-link {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--pink);
    margin-top: auto;
    transition: opacity 150ms ease;
  }
  .program-link:hover { opacity: 0.7; }
</style>
