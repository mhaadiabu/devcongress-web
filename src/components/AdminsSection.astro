---
import { Image } from 'astro:assets';

interface Social { platform: string; url: string; }
interface Admin {
  id: string;
  data: { name: string; image: string; socials: Social[]; };
}
interface Props { admins: Admin[]; }
const { admins } = Astro.props;
const sorted = [...admins].sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<section class="section" id="admins">
  <div class="container">
    <span class="eyebrow">Admins</span>
    <h2 class="heading-serif admins-heading">The people behind it</h2>
    <p class="admins-intro">A volunteer-run community. No hierarchy, no corporate structure — just builders.</p>

    <ul class="admins-grid">
      {sorted.map((admin) => (
        <li class="admin-card card">
          <div class="admin-img-wrap">
            <Image
              src={admin.data.image}
              alt={admin.data.name}
              width={400}
              height={400}
              loading="lazy"
              decoding="async"
              class="admin-img"
            />
          </div>
          <div class="admin-body">
            <h3 class="admin-name">{admin.data.name}</h3>
            <ul class="admin-socials">
              {admin.data.socials.map((s) => (
                <li>
                  <a
                    href={s.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="admin-social"
                    aria-label={`${admin.data.name} on ${s.platform}`}
                  >
                    {s.platform}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .admins-heading {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-4xl));
    margin-bottom: var(--s3);
  }

  .admins-intro {
    font-size: var(--text-base);
    color: var(--text-mid);
    margin-bottom: var(--s8);
    max-width: 520px;
  }

  .admins-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--s4);
  }
  @media (min-width: 500px)  { .admins-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
  @media (min-width: 768px)  { .admins-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); } }
  @media (min-width: 1024px) { .admins-grid { grid-template-columns: repeat(6, minmax(0, 1fr)); } }

  .admin-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .admin-img-wrap {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-bottom: 2px solid var(--black);
    background: var(--border-light);
  }

  .admin-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    filter: grayscale(0.2);
    transition: filter 300ms ease, transform 300ms ease;
  }
  .admin-card:hover .admin-img {
    filter: grayscale(0);
    transform: scale(1.04);
  }

  .admin-body {
    padding: var(--s3) var(--s3) var(--s4);
    display: flex;
    flex-direction: column;
    gap: var(--s2);
    background: var(--bg-white);
  }

  .admin-name {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--text);
    line-height: var(--leading-snug);
  }

  .admin-socials {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .admin-social {
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--text-muted);
    text-transform: capitalize;
    transition: color 150ms ease;
    padding: 2px 4px;
    border-radius: 3px;
  }
  .admin-social:hover {
    color: var(--pink);
    background: var(--pink-light);
  }
</style>
