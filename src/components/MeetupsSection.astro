---
interface MeetupLocation { name: string; map_url?: string | null; }
interface Meetup {
  id: string;
  data: {
    name: string;
    start: string;
    end: string;
    location: MeetupLocation;
    description: string;
    cover: string;
    photos?: string[];
    registration_url?: string | null;
    stream_url?: string | null;
  };
}
interface Props { meetups: Meetup[]; }
const { meetups } = Astro.props;

function getMeetupStatus(start: string, end: string) {
  const now = new Date();
  const s   = new Date(start);
  const e   = new Date(end);
  return now < s ? 'upcoming' : now <= e ? 'live' : 'past';
}

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString('en-GB', {
    day: 'numeric', month: 'long', year: 'numeric',
  });
}

const sorted = [...meetups]
  .sort((a, b) => new Date(b.data.start).getTime() - new Date(a.data.start).getTime())
  .map((m) => ({
    ...m,
    slug:   m.id,
    status: getMeetupStatus(m.data.start, m.data.end),
  }));

const recent  = sorted.slice(0, 3);
const earlier = sorted.slice(3);

const statusConfig = {
  upcoming: { label: 'Upcoming', cta: 'Register →' },
  live:     { label: '● Live',   cta: 'Watch live →' },
  past:     { label: 'Past',     cta: 'View recap →' },
};
---

<section class="section" id="meetups">
  <div class="container">

    <div class="meetups-header">
      <span class="eyebrow">Meetups</span>
      <div class="meetups-title-row">
        <h2 class="heading-serif meetups-heading">Where we show up</h2>
        <a href="/website/meetups/" class="btn btn-outline meetups-all-btn">
          All meetups →
        </a>
      </div>
    </div>

    <!-- Recent: horizontal scroll row, always visible -->
    <div class="scroll-outer">
      <ul class="meetups-scroll">
        {recent.map((meetup) => {
          const cfg        = statusConfig[meetup.status];
          const photoCount = meetup.data.photos?.length ?? 0;
          return (
            <li class="meetup-card card">
              <a href={`/website/meetups/${meetup.slug}/`} class="meetup-cover-link" aria-hidden="true" tabindex="-1">
                <div class="meetup-cover" style={`background-image: url('${meetup.data.cover}')`}>
                  <span class={`meetup-status-badge status-${meetup.status}`}>{cfg.label}</span>
                  {photoCount > 0 && (
                    <span class="meetup-photo-badge">{photoCount} photos</span>
                  )}
                </div>
              </a>
              <div class="meetup-body">
                <div class="meetup-meta">
                  <time datetime={meetup.data.start}>{formatDate(meetup.data.start)}</time>
                  <span class="meetup-location">{meetup.data.location.name}</span>
                </div>
                <h3 class="heading-serif meetup-name">
                  <a href={`/website/meetups/${meetup.slug}/`}>{meetup.data.name}</a>
                </h3>
                <p class="meetup-desc">{meetup.data.description}</p>
                <a href={`/website/meetups/${meetup.slug}/`} class="btn btn-outline meetup-cta">
                  {cfg.cta}
                </a>
              </div>
            </li>
          );
        })}
      </ul>
    </div>



  </div>
</section>


<style>
  .meetups-header {
    margin-bottom: var(--s7);
    display: flex;
    flex-direction: column;
    gap: var(--s2);
  }

  .meetups-title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--s4);
    flex-wrap: wrap;
  }

  .meetups-heading { font-size: clamp(var(--text-3xl), 5vw, var(--text-4xl)); }

  .meetups-all-btn {
    font-size: var(--text-sm);
    padding: var(--s2) var(--s5);
    flex-shrink: 0;
  }

  /* ── Horizontal scroll row ─────────────────────────────── */
  .scroll-outer {
    overflow-x: auto;
    overflow-y: visible;
    /* hide scrollbar visually but keep it functional */
    scrollbar-width: none;
    -ms-overflow-style: none;
    margin-inline: calc(-1 * var(--pad));
    padding-inline: var(--pad);
    /* bottom padding so box-shadow isn't clipped */
    padding-bottom: var(--s3);
  }
  .scroll-outer::-webkit-scrollbar { display: none; }

  .meetups-scroll {
    display: flex;
    gap: var(--s5);
    /* exactly 3 cards on desktop */
    width: max-content;
  }

  .meetups-scroll .meetup-card {
    /* desktop: exactly 1/3 of container minus gaps */
    width: calc((min(var(--max-w), 100vw) - 2 * var(--pad) - 2 * var(--s5)) / 3);
    flex-shrink: 0;
  }

  /* tablet: ~2 cards visible */
  @media (max-width: 900px) {
    .meetups-scroll .meetup-card {
      width: calc((100vw - 2 * var(--pad) - var(--s5)) / 2);
    }
  }

  /* mobile: 1.5 cards visible — scroll hint */
  @media (max-width: 600px) {
    .meetups-scroll .meetup-card {
      width: 85vw;
    }
  }


  /* ── Shared card styles ────────────────────────────────── */
  .meetup-card { overflow: hidden; display: flex; flex-direction: column; }

  .meetup-cover-link { display: block; }

  .meetup-cover {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-size: cover;
    background-position: center;
    background-color: var(--border-light);
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    padding: var(--s3);
    transition: opacity 200ms ease;
  }
  .meetup-card:hover .meetup-cover { opacity: 0.9; }

  .meetup-status-badge {
    font-size: var(--text-xs);
    font-weight: 700;
    border: 2px solid var(--black);
    border-radius: var(--r-sm);
    padding: 2px var(--s2);
  }
  .status-upcoming { background: var(--yellow);   color: var(--black); }
  .status-live     { background: var(--pink);     color: #fff; }
  .status-past     { background: var(--bg-white); color: var(--text-muted); }

  .meetup-photo-badge {
    font-size: var(--text-xs);
    font-weight: 700;
    background: rgba(0,0,0,0.6);
    color: #fff;
    border-radius: var(--r-sm);
    padding: 2px var(--s2);
  }

  .meetup-body {
    padding: var(--s5);
    display: flex;
    flex-direction: column;
    gap: var(--s3);
    flex: 1;
    border-top: 2px solid var(--black);
  }

  .meetup-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--text-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    flex-wrap: wrap;
    gap: var(--s2);
  }
  .meetup-location { color: var(--pink); }

  .meetup-name { font-size: var(--text-xl); line-height: var(--leading-snug); }
  .meetup-name a:hover { color: var(--pink); }

  .meetup-desc {
    font-size: var(--text-sm);
    color: var(--text-mid);
    line-height: var(--leading-body);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  .meetup-cta { align-self: flex-start; margin-top: var(--s2); }
</style>
