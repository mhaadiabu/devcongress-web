---
import { getCollection } from 'astro:content';
import FooterSection from '../components/FooterSection.astro';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "DevCongress | Africa's home for builders",
  description = "DevCongress is a tech community where developers, designers, founders, and makers across Africa connect, grow, and build together.",
} = Astro.props;

const siteEntries = await getCollection('site');
const site        = siteEntries[0]!.data;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#F5F2E8" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/images/favicon-180.png" />
    <!-- DM Serif Display (headlines) + Inter (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <!-- GoatCounter analytics -->
    <script data-goatcounter="https://dvevcongress.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
  </head>
  <body>
    <slot />
    <FooterSection socials={site.socials} />
  </body>
</html>

<style is:global>
  /* ─── Tokens ─────────────────────────────────────────────── */
  :root {
    /* Brand — from logo */
    --pink:          #E8117F;
    --pink-light:    #fce7f3;
    --yellow:        #F5E642;
    --yellow-dark:   #d4c100;
    --yellow-bg:     #FEFCE8;
    --black:         #111111;

    /* Surfaces */
    --bg:            #F5F2E8;   /* warm cream — primary page background */
    --bg-white:      #FFFFFF;
    --bg-yellow:     #F5E642;   /* logo yellow, section accent */
    --bg-pink:       #E8117F;   /* logo pink, section accent */

    /* Borders — solid, graphic */
    --border:        #111111;   /* 2px solid black — Dodonut-style */
    --border-light:  #E0DDD4;   /* subtle separator */

    /* Text */
    --text:          #111111;
    --text-mid:      #555555;
    --text-muted:    #888888;

    /* Typography */
    --font-serif:  'DM Serif Display', Georgia, serif;
    --font-body:   'Inter', system-ui, sans-serif;

    /* Type scale */
    --text-xs:   0.75rem;    /* 12px */
    --text-sm:   0.875rem;   /* 14px */
    --text-base: 1rem;       /* 16px */
    --text-lg:   1.125rem;   /* 18px */
    --text-xl:   1.375rem;   /* 22px */
    --text-2xl:  1.75rem;    /* 28px */
    --text-3xl:  2.5rem;     /* 40px */
    --text-4xl:  3.5rem;     /* 56px */
    --text-5xl:  5rem;       /* 80px */

    --leading-tight:  1.1;
    --leading-snug:   1.3;
    --leading-body:   1.65;

    /* Spacing */
    --s1:  0.25rem;
    --s2:  0.5rem;
    --s3:  0.75rem;
    --s4:  1rem;
    --s5:  1.5rem;
    --s6:  2rem;
    --s7:  3rem;
    --s8:  4rem;
    --s9:  6rem;
    --s10: 8rem;

    /* Layout */
    --max-w:   1200px;
    --pad:     clamp(1.25rem, 5vw, 4rem);
    --section: clamp(4rem, 8vw, 7rem);

    /* Radius */
    --r-sm:   4px;
    --r-md:   8px;
    --r-lg:   16px;
    --r-full: 9999px;

    /* Shadows — flat offset (Dodonut-style) */
    --shadow-solid:  3px 3px 0 var(--black);
    --shadow-solid-sm: 2px 2px 0 var(--black);
    --shadow-solid-lg: 5px 5px 0 var(--black);
  }

  /* ─── Reset ──────────────────────────────────────────────── */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; overflow-x: clip; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-body);
    -webkit-font-smoothing: antialiased;
    overflow-x: clip;
  }

  img, video, iframe { display: block; max-width: 100%; }
  ul, ol { list-style: none; }
  a { color: inherit; text-decoration: none; }
  button { cursor: pointer; border: none; background: none; font: inherit; }

  /* ─── Utilities ──────────────────────────────────────────── */
  .container {
    width: 100%;
    max-width: var(--max-w);
    margin-inline: auto;
    padding-inline: var(--pad);
  }

  .section { padding-block: var(--section); }

  /* Small eyebrow label above headings */
  .eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--s3);
    display: block;
  }

  /* Serif display heading */
  .heading-serif {
    font-family: var(--font-serif);
    font-weight: 400;
    line-height: var(--leading-tight);
    color: var(--text);
  }

  /* ─── Buttons — solid black border, offset shadow ────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--s2);
    padding: var(--s3) var(--s6);
    border: 3px solid var(--black);
    border-radius: var(--r-full);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    line-height: 1;
    transition: transform 100ms ease, box-shadow 100ms ease;
    white-space: nowrap;
    cursor: pointer;
  }

  .btn:hover {
    transform: translate(-2px, -2px);
    box-shadow: var(--shadow-solid);
  }
  .btn:active {
    transform: translate(0, 0);
    box-shadow: none;
  }

  .btn-primary {
    background: var(--pink);
    color: #fff;
  }

  .btn-yellow {
    background: var(--yellow);
    color: var(--black);
  }

  .btn-outline {
    background: transparent;
    color: var(--text);
  }
  .btn-outline:hover { background: var(--bg-white); }

  .btn-white {
    background: var(--bg-white);
    color: var(--black);
  }

  /* ─── Cards — solid border + offset shadow ───────────────── */
  .card {
    background: var(--bg-white);
    border: 2px solid var(--black);
    border-radius: var(--r-md);
    box-shadow: var(--shadow-solid);
    transition: transform 140ms cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 140ms ease;
  }
  .card:hover {
    transform: translate(3px, 3px);
    box-shadow: 0 0 0 transparent;
  }
  .card:hover {
    transform: translate(3px, 3px);
    box-shadow: 0 0 0 transparent;
  }

  /* ─── Divider ────────────────────────────────────────────── */
  .divider { border: none; border-top: 2px solid var(--black); }

  /* ─── Badges ─────────────────────────────────────────────── */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: var(--s1);
    padding: 3px var(--s3);
    border: 1.5px solid currentColor;
    border-radius: var(--r-full);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .badge::before { content: '●'; font-size: 6px; }

  .badge-active   { color: #059669; }
  .badge-ongoing  { color: #7c3aed; }
  .badge-upcoming { color: var(--pink); }
  .badge-completed { color: #0284c7; }

  /* ─── Marquee ────────────────────────────────────────────── */
  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .marquee-track {
    display: flex;
    gap: var(--s3);
    width: max-content;
    animation: marquee 35s linear infinite;
  }
  .marquee-track:hover { animation-play-state: paused; }

  @media (prefers-reduced-motion: reduce) {
    .marquee-track { animation: none; }
  }
</style>
